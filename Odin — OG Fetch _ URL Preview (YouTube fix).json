      "id": "d2fd2067-362f-493f-ae04-92eedda67248",
      "name": "Fetch URL HTML",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const html = $json.data || $json.body || '';\n\nfunction getOG(prop) {\n  const r1 = new RegExp(`<meta[^>]+property=[\"']og:${prop}[\"'][^>]+content=[\"']([^\"']*)[\"']`, 'i');\n  const r2 = new RegExp(`<meta[^>]+content=[\"']([^\"']*)[\"'][^>]+property=[\"']og:${prop}[\"']`, 'i');\n  const m = html.match(r1) || html.match(r2);\n  return m ? m[1].trim() : null;\n}\n\nfunction getMeta(name) {\n  const r = new RegExp(`<meta[^>]+name=[\"']${name}[\"'][^>]+content=[\"']([^\"']*)[\"']`, 'i');\n  const m = html.match(r);\n  return m ? m[1].trim() : null;\n}\n\nfunction getTitle() {\n  const m = html.match(/<title[^>]*>([^<]*)<\\/title>/i);\n  return m ? m[1].trim() : null;\n}\n\nconst title = getOG('title') || getMeta('title') || getTitle() || '';\nconst description = getOG('description') || getMeta('description') || '';\nconst image = getOG('image') || '';\nconst siteName = getOG('site_name') || '';\n\nreturn [{ json: { title, description, image, site_name: siteName } }];"
      },
