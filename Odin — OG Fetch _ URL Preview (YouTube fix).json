        "jsCode": "const url = $json.body.url || '';\nlet platform = 'other';\nif (/instagram\\.com/i.test(url)) platform = 'instagram';\nelse if (/facebook\\.com|fb\\.com|fb\\.watch/i.test(url)) platform = 'facebook';\nelse if (/maps\\.app\\.goo\\.gl|google\\.com\\/maps|goo\\.gl\\/maps/i.test(url)) platform = 'googlemaps';\nelse if (/youtube\\.com|youtu\\.be/i.test(url)) platform = 'youtube';\nreturn [{ json: { url, platform } }];"
      },
