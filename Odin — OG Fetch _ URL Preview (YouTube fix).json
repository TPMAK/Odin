      "position": [1136, 864],
      "id": "e68fe860-5434-45e7-b28d-fcc730131879",
      "name": "Google Places Find Place",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const input = $('Parse Place Name').first().json;\nconst placesRes = $json;\nconst results = placesRes.results || placesRes.candidates || [];\nconst place = results[0] || {};\n\nlet image = '';\nif (place.photos && place.photos.length > 0) {\n  const photoRef = place.photos[0].photo_reference;\n  image = `https://maps.googleapis.com/maps/api/place/photo?maxwidth=400&photo_reference=${photoRef}&key=AIzaSyCSyTntHadda6uPeNo-BXQ1KUxzzr6TDtQ`;\n}\n\nlet description = '';\nif (place.rating) {\n  description += `⭐ ${place.rating}`;\n  if (place.user_ratings_total) description += ` (${place.user_ratings_total} reviews)`;\n}\nif (place.opening_hours) {\n  description += description ? ' · ' : '';\n  description += place.opening_hours.open_now ? 'Open now' : 'Closed';\n}\n\nlet category = 'place';\nconst types = place.types || [];\nif (types.some(t => ['store','shop','shopping_mall','clothing_store','electronics_store','furniture_store','hardware_store','home_goods_store','jewelry_store','shoe_store','book_store','pet_store'].includes(t))) {\n  category = 'product';\n} else if (types.some(t => ['lawyer','plumber','electrician','doctor','dentist','hospital','physiotherapist','real_estate_agency','insurance_agency','travel_agency','accounting','car_repair','hair_care','beauty_salon','spa','gym','veterinary_care','laundry','locksmith','painter','roofing_contractor','moving_company'].includes(t))) {\n  category = 'service';\n}\n\nreturn [{\n  json: {\n    title: place.name || input.placeName || '',\n    description: description,\n    image: image,\n    address: place.formatted_address || input.placeName || '',\n    lat: place.geometry?.location?.lat?.toString() || input.lat || '',\n    lng: place.geometry?.location?.lng?.toString() || input.lng || '',\n    rating: place.rating || null,\n    rating_count: place.user_ratings_total || null,\n    category: category,\n    site_name: 'Google Maps',\n    source: 'googlemaps'\n  }\n}];"
      },
