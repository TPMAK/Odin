    {
      "parameters": {
        "url": "=https://maps.googleapis.com/maps/api/place/textsearch/json?query={{ encodeURIComponent($json.placeName) }}&{{ $json.lat && $json.lng ? 'location=' + $json.lat + ',' + $json.lng + '&radius=500' : '' }}&key=AIzaSyCSyTntHadda6uPeNo-BXQ1KUxzzr6TDtQ",
