    {
      "parameters": {
        "jsCode": "const html = $json.body || $json.data || '';\nconst headers = $json.headers || {};\n\nlet searchText = html;\n\nif (headers['x-final-url']) searchText += ' ' + headers['x-final-url'];\nif (headers.location) searchText += ' ' + headers.location;\n\nlet placeName = '';\nconst placeMatch = searchText.match(/\\/place\\/([^/@\"'&?]+)/i);\nif (placeMatch) {\n  placeName = decodeURIComponent(placeMatch[1].replace(/\\+/g, ' '));\n}\n\nlet lat = '';\nlet lng = '';\nconst coordMatch = searchText.match(/@(-?\\d+\\.\\d{4,}),(-?\\d+\\.\\d{4,})/);\nif (coordMatch) {\n  lat = coordMatch[1];\n  lng = coordMatch[2];\n}\n\nif (!lat || !lng) {\n  const centerMatch = searchText.match(/center=(-?\\d+\\.\\d+)(?:%2C|,)(-?\\d+\\.\\d+)/);\n  if (centerMatch) {\n    lat = centerMatch[1];\n    lng = centerMatch[2];\n  }\n}\n\nlet resolvedUrl = '';\nconst canonical = html.match(/<link[^>]+rel=[\"']canonical[\"'][^>]+href=[\"']([^\"']+)[\"']/i);\nif (canonical) resolvedUrl = canonical[1];\nif (!resolvedUrl) {\n  const ogUrl = html.match(/<meta[^>]+property=[\"']og:url[\"'][^>]+content=[\"']([^\"']+)[\"']/i)\n    || html.match(/<meta[^>]+content=[\"']([^\"']+)[\"'][^>]+property=[\"']og:url[\"']/i);\n  if (ogUrl) resolvedUrl = ogUrl[1];\n}\n\nif ((!lat || !lng) && resolvedUrl) {\n  const urlCoord = resolvedUrl.match(/@(-?\\d+\\.\\d{4,}),(-?\\d+\\.\\d{4,})/);\n  if (urlCoord) { lat = urlCoord[1]; lng = urlCoord[2]; }\n}\n\nreturn [{ json: { placeName, lat, lng, resolvedUrl } }];"
      },
